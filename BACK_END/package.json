{
  "name": "back_end",
  "version": "1.0.0",
  "description": "Backend SetUp",
  "main": "index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "seed": "ts-node -r reflect-metadata src/seeds/seed.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate -- -d \"src/data-source.cli.ts\"",
    "migration:run": "npm run typeorm migration:run -- -d \"src/data-source.cli.ts\"",
    "migration:revert": "npm run typeorm migration:revert -- -d \"src/config/data-source.cli.ts\"",
    "schema:export": "ts-node -r reflect-metadata src/scripts/exportSchema.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BROPATING/E-Commerce.git"
  },
  "keywords": [
    "express",
    "backend",
    "api",
    "pagination"
  ],
  "author": "BROPATING",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/BROPATING/E-Commerce/issues"
  },
  "homepage": "https://github.com/BROPATING/E-Commerce#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
